{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Build Debug",
            "type": "shell",
            "command": "${workspaceFolder}/vscode_build.sh",
            "args": ["debug"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build Debug configuration"
        },
        {
            "label": "CMake: Build Release",
            "type": "shell",
            "command": "${workspaceFolder}/vscode_build.sh",
            "args": ["release"],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Build Release configuration"
        }
    ]
}
